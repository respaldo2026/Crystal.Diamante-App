# Variables de entorno para Academia Crystal
# Copia este archivo como .env.local y agrega tus valores reales

# -------------------------------------------------
# Base app
# -------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://app.crystaldiamante.com
NEXT_PUBLIC_PORTAL_ESTUDIANTE_URL=https://app.crystaldiamante.com/portal-estudiante

# -------------------------------------------------
# Supabase
# -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xqcsftjkvcrbcetrdulq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY

# Service role (backend)
SUPABASE_SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY

# Compatibilidad con archivos que aún leen esta clave
SUPABASE_SERVICE_KEY=TU_SUPABASE_SERVICE_KEY

# -------------------------------------------------
# IA / modelos
# -------------------------------------------------
GEMINI_API_KEY=TU_GEMINI_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=TU_GOOGLE_GENERATIVE_AI_API_KEY
GEMINI_MODEL_ECONOMY=gemini-2.5-flash-lite
GEMINI_MODEL_CHAT=gemini-2.5-flash-lite
GEMINI_MODEL_SUMMARY=gemini-2.5-flash-lite

# -------------------------------------------------
# Seguridad cron y API interna
# -------------------------------------------------
CRON_SECRET=TU_CRON_SECRET
CRON_API_KEY=TU_CRON_API_KEY

# -------------------------------------------------
# WhatsApp Business Cloud API
# -------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=988822064312315
WHATSAPP_WABA_ID=1635512034083590
WHATSAPP_ACCESS_TOKEN=TU_WHATSAPP_ACCESS_TOKEN
WHATSAPP_API_KEY=TU_WHATSAPP_API_KEY

# Webhook verify tokens (usa uno o varios según integración)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=

# Plantillas generales
WHATSAPP_TEMPLATE_RECORDATORIO_PAGO=recordatorio_pago_v3
WHATSAPP_TEMPLATE_LIQUIDACION_PROFESOR=liquidacion_horas_profesor_v1
WHATSAPP_TEMPLATE_LIQUIDACION_PROFESOR_LANG=es_CO
WHATSAPP_TEMPLATE_RESUMEN_DIRECTOR=resumen_liquidacion_director

# Límites / políticas de envíos
WHATSAPP_ALLOW_TEXT_FALLBACK=true
WHATSAPP_MAX_BULK_PER_RUN=30
WHATSAPP_DELAY_BETWEEN_SENDS_MS=1200
WHATSAPP_MAX_REMINDERS_PER_PAYMENT=2
WHATSAPP_MIN_HOURS_BETWEEN_REMINDERS=20

# Followups automáticos
WHATSAPP_FOLLOWUP_MAX_PER_RUN=25
WHATSAPP_FOLLOWUP_DELAY_MS=900
WHATSAPP_AUTO_FOLLOWUP_3H_TEMPLATE=

# Alerta de materiales por ciclo (nuevo)
WHATSAPP_TEMPLATE_ALERTA_MATERIALES=alerta_materiales_ciclo_v2
WHATSAPP_TEMPLATE_ALERTA_MATERIALES_LANG=es_CO
WHATSAPP_ALERTA_MATERIALES_PHONE=3006402575
WHATSAPP_ALERTA_DIAS_ANTICIPACION=7
WHATSAPP_ALERTA_MAX_GRUPOS_POR_CORRIDA=20
WHATSAPP_ALERTA_DELAY_MS=900
WHATSAPP_ALERTA_ALLOW_TEXT_FALLBACK=true

# Director (liquidación)
WHATSAPP_DIRECTOR_PHONE=

