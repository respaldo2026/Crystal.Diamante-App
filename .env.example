# Variables de entorno para Academia Crystal
# Copia este archivo como .env.local y agrega tus valores reales

# Supabase - Claves públicas (ya están en el código)
NEXT_PUBLIC_SUPABASE_URL=https://xqcsftjkvcrbcetrdulq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ⚠️ IMPORTANTE: Service Role Key (solo para servidor)
# Esta clave NUNCA debe exponerse en el cliente
# Se usa solo en API routes (/app/api/*) para operaciones administrativas
# Obtén esta clave en: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
