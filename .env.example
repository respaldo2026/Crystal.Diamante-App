# Variables de entorno para Academia Crystal
# Copia este archivo como .env.local y agrega tus valores reales

# Supabase - Claves públicas (ya están en el código)

# Supabase - Claves públicas (solo frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xqcsftjkvcrbcetrdulq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Supabase - Service Role Key (solo backend/API)
# ⚠️ NUNCA expongas esta clave en el frontend ni la subas a git
# Usar solo en archivos de servidor (ej: /app/api/*)
# Obtén esta clave en: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# WhatsApp Business Cloud API
# Obtén estas credenciales en: Meta for Developers > WhatsApp > API Setup
# WHATSAPP_PHONE_NUMBER_ID: ID del número de teléfono (no el número en sí)
# WHATSAPP_ACCESS_TOKEN: Token de acceso permanente o temporal
# WHATSAPP_API_KEY: Clave secreta para autenticar llamadas desde Make
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui
WHATSAPP_ACCESS_TOKEN=tu_access_token_aqui
WHATSAPP_API_KEY=tu_clave_secreta_para_make

# Teléfono del director para recibir el resumen de liquidación de profesores
# Formato internacional sin + ni espacios: 573001234567
# Si no se define aquí, se busca automáticamente en la tabla perfiles donde rol='director'
WHATSAPP_DIRECTOR_PHONE=

# Feature Flags (frontend)
# Formato JSON. Ejemplo para activar/desactivar despliegues graduales.
NEXT_PUBLIC_FEATURE_FLAGS={"marketing_mobile_tables_v1":true,"marketing_prompt_tools_v1":true,"marketing_agent_knowledge_v1":true}
# Flags portal-estudiante (fase 2)
# portal_mobile_ui_v1: habilita ajustes mobile-first del portal
# portal_delayed_loader_v1: habilita loader diferido para evitar parpadeo
